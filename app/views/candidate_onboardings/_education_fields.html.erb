<div class="nested-fields border border-slate-200 rounded-lg p-4 mb-3 space-y-3">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <%= f.text_field :institution, placeholder: "Muassasa",
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    <%= f.text_field :study, placeholder: "Yo'nalish",
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    <%= f.select :level, Education::LEVELS, { include_blank: "Daraja" },
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    <%= f.date_field :start_date,
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    <%= f.date_field :end_date,
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
  </div>

  <% if f.object.from_cv? %>
    <span class="inline-block text-xs text-amber-600 bg-amber-50 px-2 py-1 rounded">
      CV'dan olindi — tekshiring
    </span>
  <% end %>

  <%= f.hidden_field :_destroy %>
  <button type="button" data-action="repeater#remove"
      class="text-sm text-red-600 hover:underline">
    O'chirish
  </button>
</div>