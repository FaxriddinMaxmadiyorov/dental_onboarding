<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<%= turbo_stream_from "cv_status_#{@profile.id}" %>

<div class="max-w-xl mx-auto py-12 text-center">
  <div id="cv_status">
    <%= render "cv_status", document: document %>
  </div>
</div>

<% if document.nil? || document.pending? || document.processing? %>
  <meta http-equiv="refresh" content="3">
<% end %>
