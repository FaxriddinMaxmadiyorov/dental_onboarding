<div class="max-w-xl mx-auto py-12">
  <h1 class="text-2xl font-semibold mb-2">Upload your CV</h1>

  <p class="text-gray-600 mb-6">
    We will automatically fill in as much of your candidate profile as
    possible. You can review and edit everything before saving.
  </p>

  <% if flash[:alert] %>
    <p class="mb-4 rounded-lg bg-red-50 px-3 py-2 text-sm text-red-600"><%= flash[:alert] %></p>
  <% end %>

  <%= form_with model: @document, url: upload_cv_candidate_onboarding_path,
      data: { controller: "cv-upload" },
      html: { novalidate: true } do |f| %>

    <div data-cv-upload-target="dropzone"
        class="border-2 border-dashed border-slate-300 rounded-lg p-10 text-center cursor-pointer transition hover:border-teal-500 hover:bg-teal-50/30">
        <%= f.file_field :file, data: {
            cv_upload_target: "input",
            action: "change->cv-upload#fileSelected"
          }, accept: ".pdf,.doc,.docx", class: "hidden" %>

      <div data-cv-upload-target="placeholder">
        <svg class="mx-auto mb-3 h-8 w-8 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 0L8 8m4-4l4 4M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2"/>
        </svg>
        <p class="text-sm text-slate-600">
          Drag and drop your file here or click to upload (PDF, DOC, DOCX, max. <%= CandidateDocument::MAX_SIZE %> MB)
        </p>
      </div>

      <div data-cv-upload-target="fileInfo" class="hidden">
        <svg class="mx-auto mb-3 h-8 w-8 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p data-cv-upload-target="fileName" class="text-sm font-medium text-slate-900"></p>
        <p data-cv-upload-target="fileSize" class="text-xs text-slate-500 mt-1"></p>
        <button type="button" data-action="cv-upload#clearFile"
            class="mt-2 text-xs text-red-600 hover:underline">
          Choose a different file
        </button>
      </div>
    </div>

    <label class="mt-4 flex items-start gap-2.5 text-sm text-slate-700">
      <%= check_box_tag :consent, "1", false,
          data: { cv_upload_target: "consentCheckbox" },
          autocomplete: "off",
          class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-teal-600 focus:ring-teal-600/40" %>
      <span>
        I agree that my CV and profile information may be processed to create and improve my candidate profile.
      </span>
    </label>

    <p data-cv-upload-target="consentError"
        class="hidden mt-2 text-sm text-red-600">
      Please provide your consent to continue.
    </p>

    <%= f.submit "Analyze CV", data: { cv_upload_target: "submitButton" },
        disabled: true,
        class: "mt-4 w-full bg-blue-600 text-white rounded py-2 disabled:opacity-40 disabled:cursor-not-allowed" %>
  <% end %>

  <%= link_to "Enter details manually", edit_profile_candidate_onboarding_path,
              class: "block text-center text-sm text-gray-500 mt-4" %>
</div>
