<div class="nested-fields border border-slate-200 rounded-lg p-4 mb-3 space-y-3">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <%= f.text_field :job_title, placeholder: "Lavozim",
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    <%= f.text_field :company_name, placeholder: "Kompaniya nomi",
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
  </div>

  <%= f.text_area :responsibilities, placeholder: "Vazifalar / mas'uliyatlar",
      rows: 3,
      class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
    <div>
      <label class="block text-xs text-slate-500 mb-1">Boshlanish sanasi</label>
      <%= f.date_field :start_date,
          class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Tugash sanasi</label>
      <%= f.date_field :end_date,
          class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <label class="flex items-center gap-2 text-sm text-slate-700">
      <%= f.check_box :current_job %>
      Hozirgi ish joyi
    </label>
  </div>

  <% if f.object.from_cv? %>
    <span class="inline-block text-xs text-amber-600 bg-amber-50 px-2 py-1 rounded">
      CV'dan olindi — tekshiring
    </span>
  <% end %>

  <%= f.hidden_field :_destroy %>
  <button type="button" data-action="repeater#remove"
      class="text-sm text-red-600 hover:underline">
    O'chirish
  </button>
</div>