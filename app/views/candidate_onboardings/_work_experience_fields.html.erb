<div class="nested-fields border border-slate-200 rounded-lg p-4 mb-3 space-y-4">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div>
      <%= f.label :job_title, "Job Title",
          class: "mb-1 block text-sm font-medium text-slate-700" %>

      <%= f.text_field :job_title,
          placeholder: "Job Title",
          class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :company_name, "Company Name",
          class: "mb-1 block text-sm font-medium text-slate-700" %>

      <%= f.text_field :company_name,
          placeholder: "Company Name",
          class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :responsibilities, "Responsibilities",
        class: "mb-1 block text-sm font-medium text-slate-700" %>

    <%= f.text_area :responsibilities,
        placeholder: "Responsibilities",
        rows: 3,
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
    <div>
      <%= f.label :start_date, "Start Date",
          class: "mb-1 block text-sm font-medium text-slate-700" %>

      <%= f.date_field :start_date,
          class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :end_date, "End Date",
          class: "mb-1 block text-sm font-medium text-slate-700" %>

      <%= f.date_field :end_date,
          class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div class="pb-2">
      <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
        <%= f.check_box :current_job %>
        Current Job
      </label>
    </div>
  </div>

  <% if f.object.from_cv? %>
    <span class="inline-block rounded bg-amber-50 px-2 py-1 text-xs text-amber-600">
      Extracted from your CV — please review
    </span>
  <% end %>

  <%= f.hidden_field :_destroy %>

  <button
    type="button"
    data-action="repeater#remove"
    class="text-sm text-red-600 hover:underline">
    Remove
  </button>
</div>