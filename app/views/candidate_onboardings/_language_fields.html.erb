<div class="nested-fields border border-slate-200 rounded-lg p-4 mb-3">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <%= f.collection_select :language_id, Language.order(:name), :id, :name,
        { include_blank: "Tilni tanlang" },
        class: "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 shadow-sm transition focus:border-teal-600 focus:outline-none focus:ring-2 focus:ring-teal-600/20" %>
    <%= f.text_field :level, placeholder: "Daraja (B2, fluent, native)",
        class: "block w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 shadow-sm transition focus:border-teal-600 focus:outline-none focus:ring-2 focus:ring-teal-600/20" %>
  </div>

  <%= f.hidden_field :_destroy %>
  <button type="button" data-action="repeater#remove"
      class="mt-2 text-sm text-red-600 hover:underline">
    O'chirish
  </button>
</div>
