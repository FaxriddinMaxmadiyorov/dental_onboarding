<h1>New candidate profile completed</h1>

<p>
  <strong><%= @profile.first_name %> <%= @profile.last_name %></strong>
  has completed the onboarding process.
</p>

<table style="border-collapse: collapse; width: 100%; max-width: 500px;">
  <tr>
    <td style="padding: 6px 0; color: #666;">Email</td>
    <td style="padding: 6px 0;"><%= @profile.email %></td>
  </tr>
  <tr>
    <td style="padding: 6px 0; color: #666;">Phone</td>
    <td style="padding: 6px 0;"><%= @profile.phone %></td>
  </tr>
  <tr>
    <td style="padding: 6px 0; color: #666;">City / Country</td>
    <td style="padding: 6px 0;"><%= @profile.city %>, <%= @profile.country %></td>
  </tr>
  <tr>
    <td style="padding: 6px 0; color: #666;">Desired job function</td>
    <td style="padding: 6px 0;"><%= @profile.desired_job_function&.humanize %></td>
  </tr>
  <tr>
    <td style="padding: 6px 0; color: #666;">Years of experience</td>
    <td style="padding: 6px 0;"><%= @profile.years_of_experience %></td>
  </tr>
</table>

<p style="margin-top: 24px;">
  <%= link_to "View full profile", @admin_url,
      style: "display: inline-block; background: #0d9488; color: #fff; padding: 10px 20px; border-radius: 8px; text-decoration: none;" %>
</p>
